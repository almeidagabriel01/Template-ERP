{
  "name": "proops-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/web"],
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "npm -w proops-web run dev",
    "build": "npm -w proops-web run build",
    "start": "npm -w proops-web run start",
    "lint": "npm -w proops-web run lint",
    "predev:backend": "npm --prefix apps/functions run build",
    "dev:backend": "concurrently -k -n functions,emulator \"npm --prefix apps/functions run build:watch\" \"npx firebase emulators:start --project dev --only functions\"",
    "deploy:dev": "npx firebase deploy --project dev --only functions,firestore:rules",
    "deploy:prod": "npx firebase deploy --project prod --only functions,firestore:rules",
    "security:audit:runtime": "npm audit --omit=dev --audit-level=critical",
    "security:audit:functions": "npm --prefix apps/functions run security:audit:runtime",
    "security:scan": "npm run security:audit:runtime && npm run security:audit:functions",
    "test:e2e": "npx playwright test --fail-on-flaky-tests",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:performance": "npx playwright test --config=playwright.perf.config.ts",
    "test:security": "npx tsx e2e/security/run-security-scan.ts",
    "test:rules": "jest --config jest.config.js",
    "test:functions": "npm --prefix apps/functions test"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@lhci/cli": "^0.15.1",
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "minimatch": "10.2.1"
  }
}
