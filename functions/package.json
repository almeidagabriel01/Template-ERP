{
  "name": "functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Template-ERP",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "deploy:dev": "firebase deploy --only functions --project erp-softcode",
    "deploy:prod": "firebase deploy --only functions --project erp-softcode-prod",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "firebase-tools": "^15.6.0",
    "typescript": "^5.3.0"
  },
  "private": true
}
