# Frontend environment variables (copy to .env.local and fill in real values)
# Never commit .env.local — it contains real credentials

# Firebase (client SDK — public values, safe as NEXT_PUBLIC_*)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "true" to point the frontend at local Firebase emulators
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Public site URL — used for SEO metadata, sitemap and robots.txt
# Dev: http://localhost:3000  |  Prod: https://proops.com.br
NEXT_PUBLIC_SITE_URL=https://proops.com.br

# Google Search Console — paste the content attribute value from the verification meta tag
# How to get: Search Console → Add property → HTML tag → content="XXX"
NEXT_PUBLIC_SEARCH_CONSOLE_VERIFICATION=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# How to get: GA4 → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_ID=
