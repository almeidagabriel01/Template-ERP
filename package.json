{
  "name": "proops",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:test": "next dev -p 3001 --env-file .env.test",
    "predev:backend": "npm --prefix functions run build",
    "dev:backend": "concurrently -k -n functions,emulator \"npm --prefix functions run build:watch\" \"npx firebase emulators:start --project dev --only functions\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "patch-package",
    "security:claims:backfill": "node scripts/backfill-custom-claims.mjs",
    "security:claims:validate": "node scripts/validate-custom-claims.mjs",
    "firestore:ttl:stripe-events": "node scripts/enable-firestore-ttl-stripe-events.mjs",
    "deploy:dev": "npx firebase deploy --project dev --only functions,firestore:rules",
    "deploy:prod": "npx firebase deploy --project prod --only functions,firestore:rules",
    "security:audit:runtime": "npm audit --omit=dev --audit-level=high",
    "security:audit:functions": "npm --prefix functions run security:audit:runtime",
    "security:scan": "npm run security:audit:runtime && npm run security:audit:functions",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:performance": "npx tsx e2e/lighthouse/run-lighthouse.ts",
    "test:security": "npx tsx e2e/security/run-security-scan.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@univerjs/preset-sheets-core": "^0.11.0",
    "@univerjs/presets": "^0.11.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^12.7.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.16",
    "lucide-react": "^0.556.0",
    "motion": "^12.34.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "recharts": "^3.5.1",
    "sileo": "^0.1.5",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": "10.2.1"
  }
}
