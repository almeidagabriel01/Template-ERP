rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Claims-based tenant source (trusted token claim)
    function getAuthTenantId() {
      return isAuthenticated() ? request.auth.token.tenantId : null;
    }

    // Claims-based role source (trusted token claim)
    function getAuthRole() {
      return isAuthenticated() ? request.auth.token.role : null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getAuthRole() in ['superadmin', 'SUPERADMIN'];
    }

    function hasTenantWriteRole() {
      return isAuthenticated()
             && getAuthRole() in [
               'admin',
               'ADMIN',
               'master',
               'MASTER',
               'wk',
               'WK',
               'superadmin',
               'SUPERADMIN'
             ];
    }

    function belongsToTenant(tenantId) {
      return isAuthenticated()
             && getAuthTenantId() != null
             && getAuthTenantId() == tenantId;
    }
    
    // Helper function to check image file size (5MB max)
    function isValidImageFileSize() {
      return request.resource.size > 0 && request.resource.size <= 5 * 1024 * 1024;
    }

    // Helper function to check attachment file size (10MB max)
    function isValidAttachmentFileSize() {
      return request.resource.size > 0 && request.resource.size <= 10 * 1024 * 1024;
    }
    
    // Helper function to allow only raster images (blocks SVG/script payloads)
    function isAllowedImageType() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp|avif)');
    }

    function isAllowedImageFolder(folder) {
      return folder == 'products' || folder == 'proposals' || folder == 'services';
    }

    function isAllowedAttachmentType() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp|avif)')
             || request.resource.contentType == 'application/pdf';
    }

    function canReadTenantPath(tenantId) {
      return isSuperAdmin() || belongsToTenant(tenantId);
    }
    
    // Tenant images - organized by tenant ID
    // Path: tenants/{tenantId}/products/{productId}/{filename}
    // Path: tenants/{tenantId}/proposals/{proposalId}/{filename}
    match /tenants/{tenantId}/{folder}/{fileName} {
      allow read: if isAllowedImageFolder(folder) && canReadTenantPath(tenantId);
      allow write: if isAllowedImageFolder(folder)
                   && canReadTenantPath(tenantId)
                   && hasTenantWriteRole()
                   && isValidImageFileSize()
                   && isAllowedImageType();
      allow delete: if isAllowedImageFolder(folder)
                    && canReadTenantPath(tenantId)
                    && hasTenantWriteRole();
    }

    match /tenants/{tenantId}/{folder}/{entityId}/{fileName} {
      allow read: if isAllowedImageFolder(folder) && canReadTenantPath(tenantId);
      allow write: if isAllowedImageFolder(folder)
                   && canReadTenantPath(tenantId)
                   && hasTenantWriteRole()
                   && isValidImageFileSize()
                   && isAllowedImageType();
      allow delete: if isAllowedImageFolder(folder)
                    && canReadTenantPath(tenantId)
                    && hasTenantWriteRole();
    }

    // Proposal attachments:
    // tenants/{tenantId}/proposals/{proposalId}/attachments/{fileName}
    match /tenants/{tenantId}/proposals/{proposalId}/attachments/{fileName} {
      allow read: if canReadTenantPath(tenantId);
      allow write: if canReadTenantPath(tenantId)
                   && hasTenantWriteRole()
                   && isValidAttachmentFileSize()
                   && isAllowedAttachmentType();
      allow delete: if canReadTenantPath(tenantId) && hasTenantWriteRole();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
