# =============================
# FRONTEND / NEXT.JS (PUBLIC)
# =============================
NEXT_PUBLIC_APP_URL=https://app.seudominio.com
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_PUBLIC_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# =============================
# FRONTEND / NEXT.JS (SERVER ONLY)
# =============================
# Nunca use NEXT_PUBLIC_ para segredos.
FIREBASE_CLIENT_EMAIL=service-account@YOUR_PROJECT.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
AUTH_SESSION_MAX_AGE_SECONDS=432000
AUTH_ACCEPT_LEGACY_COOKIE_HINT=false

# Segurança CORS (frontend/backend)
CORS_ALLOW_DYNAMIC_PREVIEW_ORIGINS=false
