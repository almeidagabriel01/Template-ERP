{
  "name": "functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for ProOps",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint .",
    "test": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "deploy:dev": "firebase deploy --project dev --only functions,firestore:rules",
    "deploy:prod": "firebase deploy --project prod --only functions,firestore:rules",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "security:audit:runtime": "npm audit --omit=dev --audit-level=critical"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@mercadopago/sdk-react": "^1.0.7",
    "@sparticuz/chromium": "^143.0.4",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "cpf-cnpj-validator": "^2.1.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.1",
    "firebase-functions": "^7.2.5",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.1.2",
    "playwright-core": "^1.58.2",
    "sanitize-html": "^2.17.2",
    "stripe": "^17.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "firebase-tools": "^15.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "@google-cloud/storage": "7.19.0",
    "fast-xml-parser": "5.3.6",
    "qs": "6.15.0"
  },
  "private": true
}
