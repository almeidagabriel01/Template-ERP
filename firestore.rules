rules_version = '2';

/**
 * Firestore Security Rules - Multi-Tenant ERP SaaS
 * 
 * SECURITY ARCHITECTURE:
 * 1. DENY BY DEFAULT: All paths not explicitly matched are denied.
 * 2. CLOUD FUNCTIONS AUTHORITY: Complex logic and critical writes (billing, quotas) MUST go through Cloud Functions.
 * 3. TENANT ISOLATION: Users can ONLY access data tagged with their `tenantId`.
 * 4. ROOT COLLECTIONS: Data attempts to be flat (proposals, clients) rather than nested, enforcing `tenantId` check on every read.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    /**
     * Check if user is authenticated
     */
    function isAuthenticated() {
      return request.auth != null;
    }
    
    /**
     * Check if authenticated user is the document owner
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    /**
     * Get the current user's document data
     * Note: In high-scale, custom claims are preferred to avoid this read. 
     * However, for strict data consistency without claims sync capability, this is acceptable.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    /**
     * Get the tenant ID for the current user.
     * Checks 'tenantId' field, with fallback to 'companyId' for legacy data.
     */
    function getUserTenantId() {
      let data = getUserData();
      return data.get('tenantId', data.get('companyId', ''));
    }
    
    /**
     * Check if the user belongs to the tenant that owns the resource.
     */
    function belongsToTenant(resourceTenantId) {
       return getUserTenantId() == resourceTenantId;
    }

    /**
     * Check if user is a super admin.
     * Super admins have full read access to all tenant data for administration.
     */
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superadmin';
    }

    /**
     * Whitelist for allowing specific field updates.
     */
    function onlyUpdatesFields(allowedFields) {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(allowedFields);
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      // READ: Own profile, Master of this user, Admin of same tenant, Member reading their Master, or Super Admin
      // Using resource.data.get() with default to avoid null errors for non-existent docs
      allow read: if isOwner(userId) 
                  || (isAuthenticated() && resource.data.get('masterId', '') == request.auth.uid)
                  || (isAuthenticated() && getUserData().role in ['admin', 'master'] && belongsToTenant(resource.data.get('tenantId', '')))
                  || (isAuthenticated() && getUserData().get('masterId', '') == userId)
                  || isSuperAdmin();
      
      // CREATE: Allowed for self-registration (user creating their own document)
      allow create: if isOwner(userId);
      
      // UPDATE: Owner can update profile info, but NOT sensitive roles/ids.
      // Super admin can update any field for tenant management.
      allow update: if isSuperAdmin()
                    || (isOwner(userId)
                        && onlyUpdatesFields(['name', 'photoUrl', 'updatedAt'])
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'masterId', 'tenantId', 'companyId', 
                                     'subscription', 'usage', 'stripeCustomerId', 'stripeSubscriptionId']));
                                 
      // DELETE: Blocked for regular users. Super admin can delete for tenant cleanup.
      allow delete: if isSuperAdmin();
      
      // PERMISSIONS SUBCOLLECTION: User can read their own permissions, their Master can, or Super Admin
      match /permissions/{permissionId} {
        allow read: if isOwner(userId) 
                    || (isAuthenticated() && get(/databases/$(database)/documents/users/$(userId)).data.get('masterId', '') == request.auth.uid)
                    || isSuperAdmin();
        allow write: if false; // Only Cloud Functions can manage permissions
      }
    }
    
    // ============================================
    // TENANT RESOURCES (Root Collections)
    // ============================================
    // Pattern: Read allowed if user's tenantId matches resource's tenantId.
    // Writes blocked (Cloud Functions only) or restricted.
    
    // PROPOSALS
    match /proposals/{proposalId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits, validation)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }
    
    // CLIENTS
    match /clients/{clientId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }
    
    // PRODUCTS
    match /products/{productId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }
    
    // TRANSACTIONS (Financial)
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.tenantId)
                  || isSuperAdmin();
      allow write: if false; // Managed by Cloud Functions (calculations)
    }
    
    // WALLETS
    match /wallets/{walletId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.tenantId)
                  || isSuperAdmin();
      allow write: if false; // Managed by Cloud Functions
    }
    
    // WALLET TRANSACTIONS (audit log)
    match /wallet_transactions/{transactionId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.tenantId)
                  || isSuperAdmin();
      allow write: if false; // Managed by Cloud Functions
    }
    
    // SISTEMAS (Automation)
    match /sistemas/{sistemaId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false;
    }
    
    // AMBIENTES (Automation)
    match /ambientes/{ambienteId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false;
    }
    
    // PROPOSAL TEMPLATES
    match /proposal_templates/{templateId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false;
    }
    
    // CUSTOM FIELDS
    match /custom_fields/{fieldId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false;
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }
    
    // CUSTOM OPTIONS (Legacy)
    match /custom_options/{optionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false;
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }
    
    // OPTIONS (Dynamic Selects)
    match /options/{optionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false;
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }
    
    // ADDONS
    match /addons/{addonId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.tenantId)
                  || isSuperAdmin();
      allow write: if false; // Managed by Stripe Webhooks
    }

    // ============================================
    // SYSTEM COLLECTIONS
    // ============================================

    // COMPANIES (Legacy/Core Tenant Info)
    match /companies/{companyId} {
      // Only members of the company can view its details
      allow read: if isAuthenticated() && getUserData().companyId == companyId;
      allow write: if false;
    }
    
    // TENANTS (New Tenant Info)
    match /tenants/{tenantId} {
      // Allow read if: super admin, user's tenantId matches, OR tenant ID matches the UID pattern (fallback for new users)
      allow read: if isSuperAdmin() || (isAuthenticated() && (
        tenantId == 'tenant_' + request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().tenantId == tenantId)
      ));
      // CREATE: Super admin can create any tenant, users can only create their own (self-registration)
      allow create: if isSuperAdmin() || (isAuthenticated() && tenantId == 'tenant_' + request.auth.uid);
      // UPDATE: Only super admin can update tenants
      allow update: if isSuperAdmin();
      // DELETE: Only super admin can delete tenants
      allow delete: if isSuperAdmin();
    }

    // PURCHASED ADDONS
    match /purchased_addons/{addonId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false; // Managed by Stripe Webhooks
    }
    
    // PLANS (Public/Reference)
    match /plans/{planId} {
      allow read: if isAuthenticated(); // Public read for plan display
      allow write: if false;
    }
    
    // PAGES (Reference)
    match /pages/{pageId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================
    // CATCH-ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
