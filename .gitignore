# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase Functions
apps/functions/node_modules
apps/functions/lib
firebase-debug.log
firebase-debug.*.log
.firebase/

# Firebase secrets (project-specific env files)
apps/functions/.env.*
!apps/functions/.env.example

# Firebase service account keys
*serviceAccount*.json
*firebase-adminsdk*.json
*-credentials.json

# Google credentials / OAuth
google-credentials.json
gcloud-credentials.json
service-account.json

# Stripe
.stripe/

# Claude Code local overrides (settings.local.json may contain personal tokens)
.claude/settings.local.json

# Firebase emulator debug logs
firestore-debug.log
ui-debug.log
database-debug.log
pubsub-debug.log
.emulator-pid

# Playwright
.last-run.json
playwright-report/
test-results/
e2e/dist/

# Test reports and results (generated locally, not committed)
lighthouse-report/
security-report/
performance-report/

# ZAP scan outputs
zap.yaml
report_json.json
report_md.md
report_html.html

# env files (can opt-in for committing if needed)
!.env.test


# Git worktrees
.worktrees/
